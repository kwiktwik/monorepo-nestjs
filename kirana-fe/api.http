### Check Authentication Status (Android App)
# Endpoint for Android app to check if request is authenticated
# Works with both cookie-based authentication and Authorization header with Bearer token
# 
# Headers:
# - Cookie: Session cookies (if using cookie-based auth)
# - Authorization: Bearer <token> (if using JWT token)
# 
# Response (200 OK):
# {
#   "authenticated": true,
#   "user": {
#     "id": "user_id",
#     "email": "user@example.com",
#     "name": "User Name",
#     "image": "https://...",
#     "emailVerified": true
#   },
#   "session": {
#     "expiresAt": "2024-12-31T23:59:59Z"
#   }
# }
# 
# Response (401 Unauthorized):
# {
#   "authenticated": false,
#   "error": "No valid session found"
# }
GET {{baseUrl}}/auth/check

