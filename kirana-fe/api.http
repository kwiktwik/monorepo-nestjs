}

### Sign In with Phone Number
# Signs in a user using phone number and password (after phone verification)
# Body Parameters:
# - phoneNumber: Phone number in E.164 format (required, e.g., "+1234567890")
# - password: User's password (required, string)
# - rememberMe: Whether to remember the session (optional, boolean, default: false)
# 
# Response: Returns user data and session cookies
POST {{baseUrl}}/auth/sign-in-phone-number
Content-Type: application/json

{
  "phoneNumber": "+1234567890",
  "password": "user_password",
  "rememberMe": true
}

