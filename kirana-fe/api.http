### Update User Profile
# Updates the current authenticated user's profile information
# 
# Headers:
# - Cookie: Session cookies (if using cookie-based auth)
# - Authorization: Bearer <token> (if using JWT token)
# 
# Body Parameters:
# - name*: User's name (required, string)
# - phoneNumber*: User's phone number (required, E.164 format, e.g., "+919876543210")
# - email: User's email (optional, string, must be valid email format)
# - upiVpa: UPI Virtual Payment Address (optional, string, format: "user@bank")
# - audioLanguage: Audio language preference (optional, string, e.g., "en", "hi")
# 
# Note: accountType is read-only and derived from the account table
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "User updated successfully",
#   "data": {
#     "id": "user_id",
#     "name": "Updated Name",
#     "phoneNumber": "+919876543210",
#     "email": "updated@example.com",
#     "accountType": "google",
#     "upiVpa": "user@paytm",
#     "audioLanguage": "en",
#     "emailVerified": true,
#     "phoneNumberVerified": true,
#     "image": null,
#     "createdAt": "2024-12-24T13:08:35.165Z",
#     "updatedAt": "2024-12-24T17:30:00.000Z"
#   }
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Name is required" | "Phone number is required" | "Invalid phone number format" | "Invalid email format" | "Invalid UPI VPA format"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
# 
# Response (500 Internal Server Error):
# {
#   "error": "Failed to update user"
# }
POST {{baseUrl}}/user
Content-Type: application/json

{
  "name": "John Doe",
  "phoneNumber": "+919876543210",
  "email": "john.doe@example.com",
  "upiVpa": "john@paytm",
  "audioLanguage": "en"
}

