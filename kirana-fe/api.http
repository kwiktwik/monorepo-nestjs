}

### ===== BACKGROUND REMOVAL API =====

### Trigger Background Removal
# Triggers background removal for an uploaded image
# This should be called AFTER the image has been successfully uploaded to R2
# 
# Headers:
# - X-App-ID: App identifier (required, e.g., "alertpay-android")
# - Authorization: Bearer token or session cookie (required)
# 
# Body Parameters:
# - imageUrl: The public URL of the uploaded image (required, string)
# - imageId: The database ID of the image record (required, number)
# - key: The R2 key for the image (required, string)
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "Background removal task queued",
#   "imageId": 123
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Missing required fields: imageUrl, imageId, key"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
# 
# Response (500 Internal Server Error):
# {
#   "error": "Failed to trigger background removal"
# }
POST {{localUrl}}/background-removal
Content-Type: application/json
X-App-ID: jamun-andriod
Authorization: Bearer {{authToken}}

{
  "imageUrl": "https://cnd.storyowl.app/jamun-andriod/WoIHGy328w69P33Tw3HfRngLRpemvUyP/user-images/1769912163965_pfp_1769912164723.png",
  "imageId": 480,
  "key": "jamun-andriod/WoIHGy328w69P33Tw3HfRngLRpemvUyP/user-images/1769912163965_pfp_1769912164723.png"
}

### ===== NOTIFICATIONS API =====

### Get Notifications (Basic)
# Query Parameters:
# - page: Page number (default: 1)
# - limit: Items per page (default: 10)
# 
# Note: Only returns notifications with isValid: true in metadata
# All notifications are stored, but only those with valid amounts are returned
# 
# Response (200 OK):
# {
#   "data": [
#     {
#       "id": 1,
#       "canReply": false,
#       "packageName": "com.phonepe.app",
#       "title": "Payment Received",
#       "content": "You received ₹500",
#       "hasRemoved": false,
#       "haveExtraPicture": false,
#       "onGoing": false,
#       "createdAt": "2024-01-01T00:00:00Z",
#       "metadata": {
#         "from": "Payment",
#         "amount": 500,
#         "isValid": true
#       }
#     }
#   ],
#   "pagination": {
#     "page": 1,
#     "limit": 10,
#     "total": 1,
#     "totalPages": 1
#   }
# }
GET {{baseUrl}}/notifications?page=1&limit=10

### Get Notifications with filters
# Query Parameters:
# - packageName: Filter by package name (exact match)
# - title: Filter by title (partial match, case-insensitive)
# - hasRemoved: Filter by removal status (true/false)
# - onGoing: Filter by ongoing status (true/false)
# - startDate: Filter notifications created on or after this date (UTC format: YYYY-MM-DD or ISO 8601)
# - endDate: Filter notifications created on or before this date (UTC format: YYYY-MM-DD or ISO 8601)
# 
# Note: Only returns notifications with isValid: true in metadata
# All notifications are stored, but only those with valid amounts are returned
GET {{baseUrl}}/notifications?page=1&limit=10&packageName=com.google.android.apps.nbu.paisa.user&title=paid&hasRemoved=false&onGoing=false

### Get Notifications with date filter (UTC format)
# Date formats supported:
# - YYYY-MM-DD (e.g., 2024-01-01) - treated as UTC midnight
# - ISO 8601 with timezone (e.g., 2024-01-01T00:00:00Z)
# Examples:
# - Single date: startDate=2024-01-01
# - Date range: startDate=2024-01-01&endDate=2024-12-31
# - Full ISO: startDate=2024-01-01T00:00:00Z&endDate=2024-12-31T23:59:59Z
# 
# Note: Only returns notifications with isValid: true in metadata
GET {{baseUrl}}/notifications?page=1&limit=10&startDate=2024-01-01&endDate=2024-12-31

### Get Notifications - Date range only
GET {{baseUrl}}/notifications?startDate=2024-01-01&endDate=2024-12-31

### Get Notifications - From start date only
GET {{baseUrl}}/notifications?startDate=2024-01-01

### Get Notifications - Until end date only
GET {{baseUrl}}/notifications?endDate=2024-12-31

### Create Notification
# Body Parameters:
# - canReply: Whether the notification can be replied to (optional, default: false)
# - packageName: Package name of the app (required, string)
# - title: Notification title (required, string)
#   Amount and sender name are automatically extracted from title or content
# - content: Notification content (optional, string)
#   If content contains a number, it will be extracted and formatted in readNotification field
# - hasRemoved: Whether the notification has been removed (optional, default: false)
# - haveExtraPicture: Whether the notification has extra picture (optional, default: false)
# - onGoing: Whether the notification is ongoing (optional, default: false)
# 
# Response (201 Created):
# Returns the created notification with metadata object containing:
# - id: Notification ID
# - canReply: Reply capability status
# - packageName: Package name
# - title: Notification title
# - content: Notification content
# - readNotification: Formatted notification message (string)
#   If content contains a number, format: "{number} received in your account"
#   If no number found, returns empty string ""
# - hasRemoved: Removal status
# - haveExtraPicture: Extra picture status
# - onGoing: Ongoing status
# - createdAt: Creation timestamp (ISO 8601)
# - metadata: Object with "from", "amount", and "isValid" fields
#   - from: Extracted sender name (string, defaults to "Unknown" if not found)
#   - amount: Extracted amount in paise (number, defaults to 0 if not found)
#   - isValid: Boolean indicating if amount is valid (true if amount > 0, false otherwise)
# 
# Note: All notifications are stored regardless of validity.
# Only notifications with isValid: true are returned in GET requests.
POST {{baseUrl}}/notifications
Content-Type: application/json

{
  "canReply": false,
  "packageName": "com.google.android.apps.nbu.paisa.user",
  "title": "AAKANKSHA JAGDALE",
  "content": "V",
  "hasRemoved": false,
  "haveExtraPicture": false,
  "onGoing": false
}

### Create Notification - With Amount in Content
# Example showing readNotification field extraction and metadata
# When content contains a number, readNotification will be formatted as "{number} received in your account"
# Metadata will include extracted amount, from, and isValid fields
POST {{baseUrl}}/notifications
Content-Type: application/json

{
  "canReply": false,
  "packageName": "com.phonepe.app",
  "title": "Payment Received",
  "content": "You received ₹500 from John Doe",
  "hasRemoved": false,
  "haveExtraPicture": false,
  "onGoing": false
}
# Expected response includes:
# - "readNotification": "500 received in your account"
# - "metadata": { "from": "Payment", "amount": 500, "isValid": true }

### ===== PUSH NOTIFICATIONS API =====
# Sends push notifications via Firebase Cloud Messaging (FCM)
# Requires: Session authentication (Cookie)

### Register Push Token
# Registers FCM device token for the authenticated user
# Body Parameters:
# - token: FCM device token (required)
# - appId: App identifier (required, e.g., "alertpay-android")
# - deviceModel: Device model (optional)
# - osVersion: OS version (optional)
#
# Response (200 OK):
# { "success": true }
POST {{baseUrl}}/notifications/register
Content-Type: application/json
Authorization: Bearer {{authToken}}


{
  "token": "enOXfQ8GSb2jm4dyIvRpbo:APA91bGHWP0f4M8u48BpRaDHypFDIDE1AxBumwiBM34HAky9Zci89YAjiDsWYvNU8Ngj4IHRxpBMbZ8rLR2-ryWnMONRdTVIzBSKl_ypwrAEComyoTBRq9k",
  "appId": "com.kiranaapps.app",
  "deviceModel": "Pixel 7",
  "osVersion": "14"
}

### Delete Push Token
# Unregisters FCM device token for the authenticated user
# Body Parameters:
# - token: FCM device token (required)
# - appId: App identifier (required)
#
# Response (200 OK):
# { "success": true }
DELETE {{baseUrl}}/notifications/register
Content-Type: application/json

{
  "token": "fcm-device-token-here",
  "appId": "alertpay-android"
}

### Send Push Notification
# Sends a push notification either to a specific FCM token or to all devices for a user
# Requires: Session authentication (Cookie)
#
# Option 1 - Send to specific device (use token):
# Body Parameters:
# - token: FCM device token (required for this option)
# - title: Notification title (required)
# - body: Notification body (required)
# - data: Extra payload key-value pairs (optional)
#
# Option 2 - Send to user's devices (use userId + appId):
# Body Parameters:
# - userId: User ID (required for this option)
# - appId: App identifier (required for this option)
# - title: Notification title (required)
# - body: Notification body (required)
# - data: Extra payload key-value pairs (optional)
#
# Response (200 OK):
# { "success": true, "method": "token" } or { "success": true, "method": "user", "userId": "...", "appId": "..." }
POST {{localUrl}}/notifications/send
Content-Type: application/json
X-App-ID: com.paymentalert.app
Authorization: Bearer 53opXcAOOByV1Kjkt3iZ7gOSnF1beacC

{
