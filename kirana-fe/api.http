### Verify One-Time Token
# Verifies a one-time token using Better Auth's oneTimeToken plugin
# One-time tokens are typically used for secure, single-use authentication flows
# 
# Body Parameters:
# - token: The one-time token to verify (required, string)
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "Token verified successfully",
#   "data": {
#     "verified": true,
#     ...
#   }
# }
# 
# Response (400 Bad Request):
# {
#   "success": false,
#   "error": "Token is required and must be a string"
# }
# 
# Response (401 Unauthorized):
# {
#   "success": false,
#   "error": "Invalid or expired token"
# }
# 
# Response (500 Internal Server Error):
# {
#   "success": false,
#   "error": "Unknown error occurred"
# }
# 
# Notes:
# - One-time tokens are single-use and expire after verification or timeout
# - Tokens must be verified within their validity period
# - Once verified, the token cannot be used again
POST {{baseUrl}}/auth/verify-one-time-token
Content-Type: application/json

{
  "token": "lfTbaSfPCoikN68tKs74UIQbOYUviMiy"
}

### Verify One-Time Token - Example
POST {{baseUrl}}/auth/verify-one-time-token
Content-Type: application/json

{
  "token": "ott_abc123xyz789"
}

### Truecaller Token Exchange and User Profile
# Exchanges authorization code for access token and fetches user profile using Truecaller OAuth2 flow
# This endpoint performs both token exchange and user profile fetching in a single call
# 
# Headers:
# - X-App-ID: App identifier (required, e.g., "alertpay-android")
# 
# Body Parameters:
# - grant_type: "authorization_code" (required, hardcoded value)
# - client_id: Your Truecaller client ID (required, string)
# - code: Authorization code from Truecaller OAuth callback (required, string)
#   This is the authorization code received from step 9 of Truecaller OAuth flow
# - code_verifier: Code verifier used in PKCE flow (required, string)
#   This is the code verifier from step 12 of Truecaller OAuth flow
# 
# Response (200 OK - Success):
# {
#   "success": true,
#   "token": "session_token_here",
#   "expires_at": "2026-02-14T15:50:00.000Z",
#   "user": {
#     "id": "user_xyz789",
#     "name": "John Doe",
#     "email": "john@example.com",
#     "phoneNumber": "+919876543210",
#     "image": "https://example.com/photo.jpg",
#     "emailVerified": true,
#     "phoneNumberVerified": true
#   },
#   "user_profile": {
#     "sub": "13627101294235520",
#     "given_name": "John",
#     "family_name": "Doe",
#     "phone_number": "91xxxxxxxxxx",
#     "email": "john@example.com",
#     "picture": "https://www.truecaller.com/xyz",
#     "gender": "male/female",
#     "phone_number_country_code": "IN",
#     "phone_number_verified": true,
#     "address": {
#       "locality": "Bangalore",
#       "postal_code": "5xxxxx"
#     }
#   },
#   "appId": "alertpay-android"
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Missing required parameters" | "Invalid grant type" | "Missing app identifier"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Invalid or disabled app identifier: <app-id>"
# }
# 
# Response (403 Forbidden):
# {
#   "error": "Forbidden - Invalid client ID, auth code, or code verifier" | "Feature 'truecallerLogin' is not enabled for app"
# }
# 
# Response (429 Too Many Requests):
# {
#   "error": "Too Many Requests - Rate limit exceeded"
# }
# 
# Response (500 Internal Server Error):
# {
#   "error": "Internal Server Error - Unexpected error on server side"
# }
# 
# Response (503 Service Unavailable):
# {
#   "error": "Service Unavailable - Resource unavailable due to server-side issue"
# }
# 
# Notes:
# - This endpoint exchanges the authorization code for an access token
# - After obtaining the token, it automatically fetches the user profile
# - Users are isolated per app (same phone number in different apps = different users)
# - Requires openid scope to be included in the initial OAuth request for profile data
POST {{baseUrl}}/truecaller/token
Content-Type: application/json
X-App-ID: alertpay-android

{
  "grant_type": "authorization_code",
  "client_id": "ydjkygwywg7arqesdggwy6fqhufyrtgja2viy714e30",
  "code": "srBLBpBKwDTR9UuR7gF_HBicO4k9SR5JaavVQp36RTDJ-NtVlmDOfzPpSEP_cjDKbBlgYMgyOiqCbygPHJxzrA==",
  "code_verifier": "1XAdYTH7B-bY8ZLj6NzXotyDdNkJwkKnSqwoeiXw92yUix9Y70rirh6wdW5KJi6LTNVDNs_7cf02bSWiCe-4jw"
}

### Truecaller Token Exchange - iOS App Example
# Same Truecaller account, different app = different user
POST {{baseUrl}}/truecaller/token
Content-Type: application/json
