### Delete User Account V1 (AlertPay App)
# Deletes the user and all associated data across ALL apps
# 
# Headers:
# - Authorization: Bearer <hardcoded-token> (required)
# - X-App-ID: App identifier (required)
# 
# Query Parameters OR Body:
# - phoneNumber: Phone number in E.164 format (required, e.g., "+919876543210")
# 
# Note: This deletes the user GLOBALLY, not just for the specific app.
# All data across all apps will be deleted:
# - All sessions (across all apps)
# - All accounts
# - All user metadata (across all apps)
# - All user images (across all apps)
# - All notifications
# - All orders
# - All subscriptions
# - The user record
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "User and all associated data deleted successfully across all apps",
#   "appId": "alertpay-android"
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Phone number is required" | "Invalid phone number format"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - invalid token" | "Invalid or disabled app identifier"
# }
# 
# Response (404 Not Found):
# {
#   "error": "User not found"
# }

### Delete User V1 by Phone Number (Request Body)
DELETE {{baseUrl}}/user/v1
Authorization: Bearer djU-4meRO1gh_zskk8cfDbRUdSByU4z6
X-App-ID: alertpay-android
Content-Type: application/json

{
  "phoneNumber": "+917888149531"
}

