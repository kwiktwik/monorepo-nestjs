### ===== AUTHENTICATION API (Old) =====
### ===== MULTI-APP AUTHENTICATION =====
# All authentication endpoints now support multi-app isolation via X-App-ID header
# 
# Registered Apps:
# - alertpay-android: AlertPay Android mobile app
# - alertpay-ios: AlertPay iOS mobile app
# - alertpay-web: AlertPay web application
# - alertpay-default: Default app for backward compatibility
# 
# User Isolation:
# - Same phone number in different apps = different user accounts
# - Users are identified by phoneNumber + appId combination
# - Sessions are scoped to specific apps
# 
# Required Header:
# X-App-ID: <your-app-id>
# 
# Error Responses:
# - 400: Missing app ID
# - 401: Invalid or disabled app ID
# - 403: Feature not enabled for app

### Send OTP (Alternative Route)
# Alternative endpoint for sending OTP using Better Auth's direct API
# This route provides the same functionality as /auth/send-otp but uses a different path
# 
# Headers:
# - X-App-ID: App identifier (required, e.g., "alertpay-android")
# 
# Body Parameters:
# - phoneNumber: Phone number in E.164 format (required, e.g., "+919876543210")
#   Must include country code (e.g., +91 for India, +1 for US)
# - appHash: Android app hash for SMS verification (optional, string)
#   Used for Android SMS retriever API to automatically read OTP
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "OTP sent successfully",
#   "data": { ... }
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Phone number is required" | "Invalid phone number format" | "Missing app identifier"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Invalid or disabled app identifier: <app-id>"
# }
# 
# Response (403 Forbidden):
# {
#   "error": "Feature 'otpLogin' is not enabled for app: <app-id>"
# }
# 
# Response (500 Internal Server Error):
# {
#   "error": "Failed to send OTP: [error message]"
# }
POST {{baseUrlProd}}/phone-number/send-otp
Content-Type: application/json
X-App-ID: alertpay-android

{
  "phoneNumber": "+918855866494",
  "appHash": "122312ere"
}

### Send OTP (Local Development)
POST {{baseUrl}}/phone-number/send-otp
Content-Type: application/json
X-App-ID: alertpay-android

{
  "phoneNumber": "+918855866494",
  "appHash": "your-app-hash-here"
}

