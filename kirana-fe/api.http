### ===== UPLOAD API =====

### Upload - Health Check
# Check the status and configuration of the presigned URL upload service
# No authentication required
# 
# Response (200 OK):
# {
#   "status": "ok",
#   "service": "presigned-url-generator",
#   "supportedFormats": ["jpg", "jpeg", "png", "gif", "webp"],
#   "maxExpiresIn": 604800,
#   "defaultExpiresIn": 3600
# }
GET {{baseUrl}}/upload/presigned-url

### Upload - Generate Presigned URL
# Generates a presigned URL for uploading user images to R2
# The uploaded file will be stored with user ID prefix: users/{userId}/{timestamp}_{fileName}
# 
# Authentication: Required (via session cookies or Bearer token)
# 
# Body Parameters:
# - fileName: Name of the file to upload (required, string)
#   Must have valid image extension: jpg, jpeg, png, gif, webp
# - contentType: MIME type of the file (optional, default: "image/jpeg")
# - expiresIn: URL expiration time in seconds (optional, default: 3600, max: 604800)
# 
# Response (200 OK):
# {
#   "success": true,
#   "uploadUrl": "https://{account}.r2.cloudflarestorage.com/...",
#   "publicUrl": "https://cnd.storyowl.app/users/{userId}/{timestamp}_{fileName}",
#   "key": "users/{userId}/{timestamp}_{fileName}",
#   "expiresIn": 3600,
#   "expiresAt": "2026-01-14T13:35:52.000Z"
# }
# 
# Response (400 Bad Request):
# {
#   "error": "fileName is required" | "Invalid file extension. Allowed: jpg, jpeg, png, gif, webp" | "expiresIn cannot exceed 604800 seconds (7 days)"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
# 
# Usage:
# 1. Call this endpoint to get uploadUrl and publicUrl
# 2. Use uploadUrl to PUT your file (with Content-Type header)
# 3. After successful upload, use publicUrl to access the file
POST {{baseUrl}}/upload/presigned-url
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "fileName": "profile-picture.jpg",
  "contentType": "image/jpeg"
}

### Upload - Generate Presigned URL with Custom Expiration
# Example with 2 hour expiration (7200 seconds)
POST {{baseUrl}}/upload/presigned-url
Content-Type: application/json

{
  "fileName": "avatar.png",
  "contentType": "image/png",
  "expiresIn": 7200
}

### Upload - Generate Presigned URL for WebP
POST {{baseUrl}}/upload/presigned-url
Content-Type: application/json

{
  "fileName": "photo.webp",
  "contentType": "image/webp",
  "expiresIn": 1800
}

### Upload - Production Example
POST {{baseUrlProd}}/upload/presigned-url
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "fileName": "user-image.jpg",
  "contentType": "image/jpeg"
}

