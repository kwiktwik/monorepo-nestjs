### ===== USER API =====

### ===== USER API V1 (Multi-App Support) =====

### Get User Profile V1 (AlertPay App)
# Fetches the current authenticated user's profile information with app-specific features
# 
# Headers:
# - Cookie: Session cookies (if using cookie-based auth)
# - Authorization: Bearer <token> (if using JWT token)
# - X-App-ID: App identifier (required, e.g., "alertpay-android", "jamun-android")
# 
# App-Specific Features:
# - AlertPay apps: includes isPremium, upiVpa, audioLanguage, orders, subscriptions
# - Sharekaro apps: basic profile only
# - All apps: includes images array
# 
# Response (200 OK - AlertPay):
# {
#   "success": true,
#   "data": {
#     "id": "user_id",
#     "name": "User Name",
#     "phoneNumber": "+919876543210",
#     "email": "user@example.com",
#     "accountType": "google" | "otp" | "truecaller" | "phoneNumber",
#     "emailVerified": true,
#     "phoneNumberVerified": true,
#     "image": "https://..." | null,
#     "images": [{ "id": 1, "imageUrl": "https://url1.com" }, { "id": 2, "imageUrl": "https://url2.com" }],
#     "createdAt": "2024-12-24T13:08:35.165Z",
#     "updatedAt": "2024-12-24T13:18:52.332Z",
#     "appId": "alertpay-android",
#     "upiVpa": "user@paytm" | null,
#     "audioLanguage": "en-US",
#     "isPremium": true
#   }
# }
# 
# Response (200 OK - Sharekaro):
# {
#   "success": true,
#   "data": {
#     "id": "user_id",
#     "name": "User Name",
#     "phoneNumber": "+919876543210",
#     "email": "user@example.com",
#     "accountType": "google",
#     "emailVerified": true,
#     "phoneNumberVerified": true,
#     "image": "https://..." | null,
#     "images": [{ "id": 1, "imageUrl": "https://url1.com" }],
#     "createdAt": "2024-12-24T13:08:35.165Z",
#     "updatedAt": "2024-12-24T13:18:52.332Z",
#     "appId": "jamun-android"
#   }
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session" | "Invalid or disabled app identifier"
# }
# 
# Response (404 Not Found):
# {
#   "error": "User not found"
# }
GET {{baseUrlProd}}/user/v1
X-App-ID: com.paymentalert.app
Authorization: Bearer zxOdW2HWH0te60vZ4r0hlgsCVgg6O3Hq

### Get User Profile V1 (AlertPay - Production)
GET {{localUrl}}/user/v1
X-App-ID: com.kiranaapps.app

### Get User Profile V1 (Sharekaro App)
GET {{baseUrl}}/user/v1
X-App-ID: jamun-android

### Update User Profile V1 (AlertPay App)
# Updates the current authenticated user's profile with app-specific fields
# 
# Headers:
# - Cookie: Session cookies (if using cookie-based auth)
# - Authorization: Bearer <token> (if using JWT token)
# - X-App-ID: App identifier (required)
# 
# Body Parameters:
# - name*: User's name (required, string)
# - phoneNumber*: User's phone number (required, E.164 format, e.g., "+919876543210")
# - email: User's email (optional, string, must be valid email format)
# - upiVpa: UPI VPA (optional, AlertPay apps only, format: "user@bank")
# - audioLanguage: Audio language (optional, AlertPay apps only, e.g., "en-US", "hi-IN")
# - images: Array of image URLs (optional, replaces all existing images for this app)
# 
# App-Specific Field Validation:
# - upiVpa: Only allowed for AlertPay apps, returns 400 for other apps
# - audioLanguage: Only allowed for AlertPay apps, returns 400 for other apps
# - images: Allowed for all apps
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "User updated successfully",
#   "data": {
#     "id": "user_id",
#     "name": "Updated Name",
#     "phoneNumber": "+919876543210",
#     "email": "updated@example.com",
#     "accountType": "google",
#     "emailVerified": true,
#     "phoneNumberVerified": true,
#     "image": null,
#     "image": null,
#     "images": [{ "id": 1, "imageUrl": "https://url1.com" }, { "id": 2, "imageUrl": "https://url2.com" }],
#     "createdAt": "2024-12-24T13:08:35.165Z",
#     "updatedAt": "2024-12-24T17:30:00.000Z",
#     "appId": "alertpay-android",
#     "upiVpa": "user@paytm",
#     "audioLanguage": "en-US"
#   }
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Name is required" | 
#            "Phone number is required" | 
#            "Invalid phone number format" | 
#            "Invalid email format" | 
#            "Invalid UPI VPA format" |
#            "UPI VPA field is not supported for jamun-android" |
#            "Audio language field is not supported for jamun-android" |
#            "Images must be an array of URLs" |
#            "Invalid image URL format"
# }
POST {{baseUrl}}/user/v1
Content-Type: application/json
X-App-ID: alertpay-android

{
  "name": "John Doe",
  "phoneNumber": "+919876543210",
  "email": "john.doe@example.com",
  "upiVpa": "john@paytm",
  "audioLanguage": "en-US",
  "images": [
    "https://cnd.storyowl.app/users/user123/profile1.jpg",
    "https://cnd.storyowl.app/users/user123/profile2.jpg"
  ]
}

