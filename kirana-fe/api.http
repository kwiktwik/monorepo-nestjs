### Get Play Store Ratings
# Retrieves Play Store ratings with pagination
# 
# Authentication: Required (via session cookies or Bearer token)
# App ID Required: X-App-ID header (e.g., "alertpay-android")
# 
# Query Parameters:
# - userId: Filter by user ID (optional, defaults to current user)
# - appId: Filter by app ID (optional, defaults to request app ID)
# - submitted: Filter by submission to Play Store - "true" | "false" (optional; omit for all)
# - limit: Maximum number of ratings to return (optional, default: 50, max: 100)
# - offset: Number of ratings to skip (optional, default: 0)
# 
# Response (200 OK):
# {
#   "success": true,
#   "data": {
#     "ratings": [
#       {
#         "id": 1,
#         "userId": "user_xyz789",
#         "appId": "alertpay-android",
#         "rating": 5,
#         "review": "Great app!",
#         "reviewTitle": null,
#         "packageName": "com.alertpay.app",
#         "appVersion": "1.2.3",
#         "deviceModel": "Pixel 7",
#         "osVersion": "14",
#         "language": "en-US",
#         "submittedToPlayStoreAt": "2026-01-30T12:00:00.000Z",
#         "createdAt": "2026-01-30T12:00:00.000Z",
#         "updatedAt": "2026-01-30T12:00:00.000Z"
#       }
#     ],
#     "pagination": {
#       "total": 10,
#       "limit": 50,
#       "offset": 0,
#       "hasMore": false
#     }
#   }
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session" | "Invalid or disabled app identifier"
# }
# 
# Response (500 Internal Server Error):
# {
#   "error": "Failed to retrieve ratings"
# }
GET {{baseUrl}}/playstore-rating
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### Get Play Store Ratings - With Pagination
GET {{baseUrl}}/playstore-rating?limit=20&offset=0
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### Get Play Store Ratings - Filter by User
GET {{baseUrl}}/playstore-rating?userId=user_xyz789&limit=10
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### Get Play Store Ratings - Filter by App
GET {{baseUrl}}/playstore-rating?appId=alertpay-android&limit=50
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### Get Play Store Ratings - Only Not Submitted to Play Store
GET {{baseUrl}}/playstore-rating?submitted=false
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### Get Play Store Ratings - Only Submitted to Play Store
GET {{baseUrl}}/playstore-rating?submitted=true
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### Get Play Store Ratings - Production
GET {{baseUrlProd}}/playstore-rating?limit=50
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### Mark Play Store Rating as Submitted
# Marks a rating as submitted to the Play Store (sets submittedToPlayStoreAt).
# Only the rating owner can update. Idempotent: if already submitted, returns current state.
#
# Path: :id = rating ID (integer)
#
# Response (200 OK):
# {
#   "success": true,
#   "message": "Rating marked as submitted to Play Store",
#   "data": { ...rating with submittedToPlayStoreAt set }
# }
#
# Response (404): Rating not found or access denied
PATCH {{baseUrl}}/playstore-rating/1
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

