### Verify Phone Number with OTP (Alternative Route)
# Alternative endpoint for verifying OTP using Better Auth's direct API
# This route provides the same functionality as /auth/verify-otp but uses a different path
# 
# Headers:
# - X-App-ID: App identifier (required, e.g., "alertpay-android")
# 
# Body Parameters:
# - phoneNumber: Phone number in E.164 format (required, e.g., "+919876543210")
#   Must match the phone number used in send-otp request
# - code: The OTP code received via SMS (required, string, typically 4-8 digits)
# - disableSession: Whether to disable session creation (optional, default: false)
#   If true, no session will be created after verification
# - updatePhoneNumber: Whether to update the phone number if user exists (optional, default: true)
#   If true, updates the user's phone number if they already exist
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "OTP verified successfully",
#   "data": {
#     "status": true,
#     "token": "session_token_here",
#     "user": {
#       "id": "user_id",
#       "phoneNumber": "+919876543210",
#       "phoneNumberVerified": true,
#       ...
#     },
#     "appId": "alertpay-android"
#   }
# }
# Response includes Set-Cookie headers for session management (if disableSession is false)
# 
# Response (400 Bad Request):
# {
#   "error": "Phone number is required" | "OTP code is required" | "Invalid format" | "Missing app identifier"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Invalid or expired OTP code" | "Invalid or disabled app identifier"
# }
# 
# Response (403 Forbidden):
# {
#   "error": "Feature 'otpLogin' is not enabled for app: <app-id>"
# }
# 
# Response (500 Internal Server Error):
# {
#   "error": "Failed to verify OTP: [error message]"
# }
# 
# Notes:
# - OTP must be verified within the validity period
# - After successful verification, user session is established (unless disableSession is true)
# - Session cookies are automatically set in the response (if disableSession is false)
# - Users are isolated per app (same phone number in different apps = different users)
POST {{baseUrlProd}}/phone-number/verify
Content-Type: application/json
X-App-ID: alertpay-android

{
  "phoneNumber": "+918855866494",
  "code": "485019"
}

### Verify Phone Number - Without Session
POST {{baseUrl}}/phone-number/verify
Content-Type: application/json
X-App-ID: alertpay-android

{
  "phoneNumber": "+918855866494",
  "code": "431882",
  "disableSession": true,
  "updatePhoneNumber": true
}

