### ===== PHONEPE APIs =====
# 
# 🔒 SECURITY NOTE: Environment switching is restricted to team members only
# 
# Environment Control Methods:
# 1. Query Parameter: ?env=DEV or ?env=PROD (team members only)
# 2. HTTP Header: X-PhonePe-Env: DEV or PROD (team members only)
# 
# Team Member IDs are configured in TEAM_MEMBER_IDS environment variable
# Non-team users will always use default environment based on NODE_ENV
# 
# === DEVELOPMENT MODE (Sandbox) ===
# Uses test credentials - no real transactions
# Merchant ID: PGTESTPAYUAT (or PHONEPE_MERCHANT_ID_DEV)
# 
# === PRODUCTION MODE (Live) ===
# Uses real credentials - actual transactions occur
# Merchant ID: PHONEPE_MERCHANT_ID_PROD
# 
# =========================================

### Get Auth Token (Mobile) - Development Mode
# Generates a Bearer token for PhonePe mobile SDK operations.
# Uses DEV credentials in SANDBOX mode.
# 
# Team members can override environment: Add header X-PhonePe-Env: PROD
POST {{baseUrl}}/phonepe
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "action": "get-auth-token"
}
### Get PhonePe SDK Configuration
# Retrieves the configuration required to initialize the PhonePe SDK on the client side.
POST {{baseUrl}}/phonepe
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer J2pkBto2dMNgEWTe7eO8D2I28MMReWih
X-PhonePe-Env: DEV

{
  "action": "get-sdk-config"
}

### Get Auth Token (Mobile) - Force Production Mode
# 🚨 TEAM MEMBERS ONLY - Production environment override
# Non-team members will receive 403 Forbidden error
POST {{baseUrl}}/phonepe
Content-Type: application/json
X-App-ID: alertpay-android
X-PhonePe-Env: PROD
Authorization: Bearer {{authToken}}

{
  "action": "get-auth-token"
}

### Setup Subscription (Autopay Mobile SDK) - Development
# Initiates a subscription setup flow for PhonePe Mobile SDK.
# Returns an order token and generates a local subscription record.
# Uses sandbox environment by default for safety.
POST {{localUrl}}/phonepe
Content-Type: application/json
X-App-ID: com.kiranaapps.app
Authorization: Bearer {{authToken}}

{
  "action": "setup-subscription",
  "maxAmount": 500,
  "frequency": "MONTHLY",
  "authWorkflowType": "TRANSACTION",
  "amount": 1,
  "amountType": "VARIABLE",
  "redirectUrl": "alertpay://payment-callback"
}

### Setup Subscription - Force Production Mode
# 🚨 TEAM MEMBERS ONLY - Production environment override
# This will create REAL subscriptions that charge actual money
POST {{baseUrl}}/phonepe
Content-Type: application/json
X-App-ID: com.kiranaapps.app
X-PhonePe-Env: PROD
Authorization: Bearer {{authToken}}

{
  "action": "setup-subscription",
  "maxAmount": 500,
  "frequency": "MONTHLY",
  "authWorkflowType": "TRANSACTION",
  "amount": 1,
  "amountType": "VARIABLE",
  "redirectUrl": "alertpay://payment-callback"
}

### Create Order Token (Mobile SDK) - Detailed
# Creates an order token specifically for the PhonePe Mobile SDK.
# Includes detailed payment flow configuration.
POST {{baseUrl}}/phonepe
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "action": "create-order-token",
  "amount": 100,
  "redirectUrl": "alertpay://payment-callback",
  "disablePaymentRetry": false,
  "merchantOrderId": "TX123456",
  "expireAfter": 1200,
  "metaInfo": {
      "udf1": "additional-info-1"
  },
  "paymentFlow": {
      "type": "PG_CHECKOUT",
      "paymentModeConfig": {
          "enabledPaymentModes": [
              { "type": "UPI_INTENT" },
              { "type": "UPI_COLLECT" },
              { "type": "UPI_QR" },
              { "type": "NET_BANKING" },
              { "type": "CARD", "cardTypes": ["DEBIT_CARD", "CREDIT_CARD"] }
          ],
          "disabledPaymentModes": []
      }
  }
}

