Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "image_url": "https://img.freepik.com/free-photo/bearded-man-denim-shirt-round-glasses_273609-11768.jpg?w=2000"
}

### Test Background Removal via File Upload (Next.js Proxy)
# functionality depends on HTTP client support for file uploads
POST {{baseUrl}}/image-processing/remove-bg
Content-Type: multipart/form-data; boundary=boundary
Authorization: Bearer {{authToken}}

--boundary
Content-Disposition: form-data; name="file"; filename="test_image.jpg"
Content-Type: image/jpeg

