### ===== PHONEPE PG APIs (Payment Gateway - Node.js SDK) =====
# REST-style endpoints using the official pg-sdk-node
# Docs: https://developer.phonepe.com/payment-gateway/backend-sdk/nodejs-be-sdk
#
# All endpoints require:
# - X-App-ID: App identifier (e.g., alertpay-android)
# - Authorization: Bearer token (except webhook)

### PG - Create SDK Order
# Creates a PhonePe SDK Order token for mobile SDK flows.
# Returns orderId, phonepeOrderId, state, expireAt, token
POST {{baseUrl}}/phonepe/pg/create-sdk-order
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "amount": 100,
  "redirectUrl": "alertpay://payment-callback",
  "disablePaymentRetry": false
}

### PG - Initiate Payment
# Initiates a PhonePe Standard Checkout payment (web redirect flow).
# Returns orderId, phonepeOrderId, state, redirectUrl, expireAt
POST {{baseUrl}}/phonepe/pg/initiate-payment
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "amount": 100,
  "redirectUrl": "https://example.com/callback",
  "message": "Payment for order",
  "meta": {
    "udf1": "user-defined-field-1",
    "udf2": "user-defined-field-2"
  }
}

### PG - Get Order Status
# Checks the status of a PhonePe order.
# Query param: merchantOrderId (required)
GET {{baseUrl}}/phonepe/pg/order-status?merchantOrderId=ORD12345678
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

### PG - Refund
# Initiates a refund for a completed order.
POST {{baseUrl}}/phonepe/pg/refund
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "originalMerchantOrderId": "ORD12345678",
  "amount": 50,
  "merchantRefundId": "RF_REFUND_001"
}

### PG - Webhook (Callback)
# PhonePe calls this endpoint for payment/refund callbacks.
# Requires Basic Auth: PHONEPE_PG_WEBHOOK_USERNAME / PHONEPE_PG_WEBHOOK_PASSWORD
# Not typically called manually - listed for reference
POST {{baseUrl}}/phonepe/pg/webhook
Content-Type: application/json
# Authorization: Basic <base64(username:password)> - set when testing


### ===== VIDEO OVERLAY API =====

### Video Overlay - Health Check
# Check the status and configuration of the video overlay service
# No authentication required
# 
# Response (200 OK):
# {
#   "status": "ok",
#   "service": "video-overlay",
#   "maxVideoSize": 104857600,
#   "maxOverlays": 10,
#   "supportedVideoFormats": ["mp4", "mov", "avi", "webm"],
#   "supportedImageFormats": ["png", "jpg", "jpeg", "gif", "webp"]
# }
GET {{baseUrl}}/video/overlay

### Video Overlay - Single Image at Fixed Position
# Overlays a single image on a video at specified coordinates
# 
# Authentication: Required (via session cookies or Bearer token)
# 
# Body Parameters:
# - videoUrl: URL of the video to process (required, string)
# - overlays: Array of overlay configurations (required, array)
#   
#   Image Source (one required):
#   - imageUrl: URL of image to overlay (optional if imageData provided, string)
#   - imageData: Base64 encoded image data (optional if imageUrl provided, string)
#   
#   Shape Configuration (optional):
#   - imageShape: Shape of the overlay (optional, "CIRCLE" | "RECTANGLE" | "ROUNDED_RECTANGLE")
#   - shapeImageUrl: URL of separate shape image (optional, string)
#   
#   Absolute Positioning (legacy support - pixels):
#   - x: X coordinate in pixels (optional if percentage positioning provided, number)
#   - y: Y coordinate in pixels (optional if percentage positioning provided, number)
#   - width: Resize width in pixels (optional, number)
#   - height: Resize height in pixels (optional, number)
#   
#   Percentage-Based Positioning (Android-compatible):
#   - namePercentageWidth: Width of text/name overlay as % of video width (optional, 0-100)
#   - imagePercentageWidth: Width of image as % of video width (optional, 0-100)
#   - namePercentageBottom: Distance from bottom as % of video height (optional, 0-100)
#   - namePercentageFromTop: Distance from top as % of video height (optional, 0-100)
#   - imagePercentageFromTop: Image distance from top as % of video height (optional, 0-100)
#   - namePercentageFromStart: Distance from left/start as % of video width (optional, 0-100)
#   - imagePercentageFromStart: Image distance from left/start as % of video width (optional, 0-100)
#   
#   Timing (optional):
#   - startTime: When to start showing overlay in seconds (optional, number)
#   - endTime: When to stop showing overlay in seconds (optional, number)
#   
#   Note: Either absolute (x, y) OR percentage-based positioning is required.
#         Percentage positioning takes precedence if both are provided.
# 
# Response (200 OK):
# {
#   "success": true,
#   "videoUrl": "https://your-r2-bucket.com/videos/processed_1234567890.mp4",
#   "processingTime": 15234
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Invalid overlay config: x and y coordinates must be numbers"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
# 
# Response (500 Internal Server Error):
# {
#   "success": false,
#   "error": "Video processing failed: [error details]",
#   "processingTime": 5234
# }
POST {{baseUrl}}/video/overlay
Content-Type: application/json
Authorization: Bearer qGWgpW0BoK6ByyyfvEoDfC8hyxQiFK8s

{
  "videoUrl": "https://media.crafto.app/enhanced-video/0d336dda-d3d5-4408-8056-fb1cfaa94c8e?dimension=480x720&size=3102852&vbr=1032609&abr=96599&type=Devotional&enhancedVideo=true",
  "overlays": [
    {
      "imageUrl": "https://media.crafto.app/profile/62x62/b458c7ec-9f96-493a-97a6-c274063dd807?dimension=62x62",
      "startTime": 0,
      "endTime": 21.9,
      "imageShape": "BLURRED CIRCLE",
      "shapeImageUrl": "https://media.crafto.app/shape/62x62/b458c7ec-9f96-493a-97a6-c274063dd807?dimension=62x62",
      "namePercentageWidth": null,
      "imagePercentageWidth": 36.76,
      "namePercentageBottom": null,
      "namePercentageFromTop": null,
      "imagePercentageFromTop": 69.22,
      "namePercentageFromStart": null,
      "imagePercentageFromStart": 47.06
    }
  ]
}

