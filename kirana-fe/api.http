### ===== RAZORPAY UPI RECURRING PAYMENTS =====


### 2. Create One-Time Order
# Note: Receipt is automatically generated by the server
POST {{baseUrl}}/razorpay/orders
Content-Type: application/json

{
  "amount": 10000,
  "currency": "INR",
  "payment_method": "upi",
  "upi": {
    "vpa": "success@razorpay",
    "flow": "collect"
  },
  "notes": {
    "purpose": "one-time payment"
  }
}

### 3. Create Recurring Order (UPI Autopay) - Monthly
# Note: Receipt is automatically generated by the server
# 
# BACKEND DEFAULTS (when token is not provided):
# - frequency: "monthly"
# - max_amount: amount * 12 (e.g., 100 * 12 = 1200)
# - expire_at: 30 days from now (Unix timestamp)
#
# Valid frequency values: "daily", "weekly", "monthly", "yearly", "as_presented"
# Backend automatically calculates max_amount based on frequency:
#   - daily: amount * 365
#   - weekly: amount * 52
#   - monthly: amount * 12
#   - yearly: amount * 1
#   - as_presented: amount * 12 (defaults to monthly multiplier)
POST {{baseUrlProd}}/razorpay/orders
Content-Type: application/json

{
  "amount": 100,
  "currency": "INR",
  "payment_method": "upi",
  "upi": {
      "vpa": "rajatdhoot@ybl",
      "flow": "collect"
  },
  "isRecurring": true,
  "token": {
      "frequency": "monthly",
      "max_amount": 1200,
      "expire_at": 1735689600
  },
  "notes": {
      "name": "Rajat Dhoot",
      "email": "rajatdhoot123@gmail.com",
      "contact": "+918855866494"
  }
}

