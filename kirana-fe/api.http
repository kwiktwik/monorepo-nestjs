### ===== PLAY STORE RATING API =====

### Store Play Store Rating
# Stores a user's Play Store rating and review
# 
# Authentication: Required (via session cookies or Bearer token)
# App ID Required: X-App-ID header (e.g., "alertpay-android")
# 
# Body Parameters:
# - rating*: Rating value from 1 to 5 (required, integer)
# - review: Review text (optional, string, max 5000 characters)
# - reviewTitle: Review title (optional, string, max 200 characters)
# - packageName: Package name of the app (optional, string, e.g., "com.example.app")
# - appVersion: App version when rating was submitted (optional, e.g., "1.2.3")
# - deviceModel: Device model (optional, e.g., "Pixel 7")
# - osVersion: Android OS version (optional, e.g., "14")
# - language: Review language/locale (optional, e.g., "en-US")
# - submittedToPlayStore: If true, marks this rating as submitted to Play Store (optional, default: false)
# 
# Response (200 OK):
# {
#   "success": true,
#   "message": "Rating stored successfully",
#   "data": {
#     "id": 1,
#     "userId": "user_xyz789",
#     "appId": "alertpay-android",
#     "rating": 5,
#     "review": "Great app!",
#     "reviewTitle": null,
#     "packageName": "com.alertpay.app",
#     "appVersion": "1.2.3",
#     "deviceModel": "Pixel 7",
#     "osVersion": "14",
#     "language": "en-US",
#     "submittedToPlayStoreAt": null,
#     "createdAt": "2026-01-30T12:00:00.000Z",
#     "updatedAt": "2026-01-30T12:00:00.000Z"
#   }
# }
# 
# Response (400 Bad Request):
# {
#   "error": "Rating is required" | "Rating must be a number between 1 and 5" | "Review text must be less than 5000 characters" | "Review title must be less than 200 characters"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session" | "Invalid or disabled app identifier"
# }
# 
# Response (404 Not Found):
# {
#   "error": "User not found"
# }
# 
# Response (500 Internal Server Error):
# {
#   "error": "Failed to store rating"
# }
POST {{baseUrl}}/playstore-rating
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "rating": 5,
  "review": "Great app! Very useful for tracking payments.",
  "packageName": "com.alertpay.app"
}

### Store Play Store Rating - With All Optional Fields
POST {{baseUrl}}/playstore-rating
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "rating": 5,
  "review": "Excellent app! Highly recommended.",
  "reviewTitle": "Best payment app",
  "packageName": "com.alertpay.app",
  "appVersion": "1.2.3",
  "deviceModel": "Pixel 7",
  "osVersion": "14",
  "language": "en-US",
  "submittedToPlayStore": false
}

### Store Play Store Rating - Mark as Submitted to Play Store
POST {{baseUrl}}/playstore-rating
Content-Type: application/json
X-App-ID: alertpay-android
Authorization: Bearer {{authToken}}

{
  "rating": 5,
  "review": "Love this app!",
  "submittedToPlayStore": true
}

