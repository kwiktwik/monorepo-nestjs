{
  "name": "kwiktwik-kirana-be",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "test:db:setup": "drizzle-kit generate --config=drizzle.test.config.ts",
    "pretest": "npm run test:db:setup",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:mock": "USE_MOCK_DB=true pnpm test:db:setup && USE_MOCK_DB=true nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:mock": "USE_MOCK_DB=true jest --config ./test/jest-e2e.json",
    "db:check": "node scripts/check-db.mjs",
    "db:inspect-otp": "node scripts/inspect-otp.mjs",
    "db:push": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit push",
    "db:push:rds": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit push",
    "db:studio:tunnel": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:copy-quotes": "node scripts/copy-quotes-from-kirana-fe.mjs",
    "manage-users": "node scripts/manage-users.mjs",
    "generate:jwt": "node scripts/generate-mock-jwt.mjs",
    "test:checkout-abandoned": "node scripts/test-checkout-abandoned.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "bullmq": "^5.30.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "drizzle-orm": "^0.45.1",
    "firebase-admin": "^13.6.1",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.4.2",
    "ioredis-mock": "^8.9.0",
    "jsonwebtoken": "^9.0.3",
    "mixpanel": "^0.20.0",
    "nanoid": "^5.1.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "pg-sdk-node": "^2.0.2",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/mixpanel": "^2.14.9",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.9",
    "drizzle-pgmem": "^0.6.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "pg-mem": "^3.0.14",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/(?!(nanoid)/)"
    ],
    "moduleNameMapper": {
      "^nanoid$": "<rootDir>/test/__mocks__/nanoid.js"
    }
  }
}