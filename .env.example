# Server Configuration
PORT=4010
NODE_ENV=development


REDIS_URL=
# Database Configuration
# ======================
# For drizzle, DATABASE_URL must be a full connection string:
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Note: Special characters in PASSWORD must be URL-encoded.
#
# Local Development (SSH tunnel example):
# 1. Start SSH tunnel (example):
#    ssh -L 5433:your-db.cluster-xyz.us-east-1.rds.amazonaws.com:5432 user@bastion-host -N
# 2. Use localhost:5433 in the connection string:
DATABASE_URL=postgresql://postgres:your-url-encoded-password@localhost:5433/kiranaapps

# Keep these for runtime modules that still use discrete values (optional):
DB_NAME=kiranaapps
DB_PORT=5433
DB_USER=postgres
RDS_PASSWORD=your-password

# Production (Amazon RDS):
# DATABASE_URL=postgresql://postgres:your-url-encoded-password@your-db.cluster-xyz.us-east-1.rds.amazonaws.com:5432/kiranaapps
# DB_NAME=kiranaapps
# DB_PORT=5432
# DB_USER=postgres
# RDS_PASSWORD=your-secure-rds-password

# Connection Pool Settings (optional)
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=10000

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Equence SMS API
EQUENCE_USERNAME=your-equence-username
EQUENCE_PASSWORD=your-equence-password
EQUENCE_SENDER_ID=ALRTSN
EQUENCE_TMPL_ID=1707176553065211775

# Razorpay - Multi-app configuration
# Each app needs its own credentials and webhook secret
# App ID format: com.example.app -> COM_EXAMPLE_APP (dots to underscores, uppercase)

# com.paymentalert.app
RAZORPAY_KEY_ID_COM_PAYMENTALERT_APP=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET_COM_PAYMENTALERT_APP=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET_COM_PAYMENTALERT_APP=your-webhook-secret

# com.sharekaro.kirana
RAZORPAY_KEY_ID_COM_SHAREKARO_KIRANA=rzp_live_yyyyyyyy
RAZORPAY_KEY_SECRET_COM_SHAREKARO_KIRANA=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET_COM_SHAREKARO_KIRANA=your-webhook-secret

# Add more apps as needed following the same pattern

# PhonePe Payment Gateway - Multi-app configuration
# =================================================
# Each app needs its own credentials following the pattern:
# App ID format: com.example.app -> COM_EXAMPLE_APP (dots to underscores, uppercase)

# Global default environment (SANDBOX or PRODUCTION) - used if not set per app
PHONEPE_ENV=SANDBOX

# com.paymentalert.app
PHONEPE_CLIENT_ID_COM_PAYMENTALERT_APP=your-sandbox-client-id
PHONEPE_CLIENT_SECRET_COM_PAYMENTALERT_APP=your-sandbox-client-secret
PHONEPE_MERCHANT_ID_COM_PAYMENTALERT_APP=PGTESTPAYUAT
PHONEPE_SALT_KEY_COM_PAYMENTALERT_APP=your-sandbox-salt-key
PHONEPE_SALT_INDEX_COM_PAYMENTALERT_APP=1
PHONEPE_CLIENT_VERSION_COM_PAYMENTALERT_APP=1

# com.sharekaro.kirana
PHONEPE_CLIENT_ID_COM_SHAREKARO_KIRANA=your-production-client-id
PHONEPE_CLIENT_SECRET_COM_SHAREKARO_KIRANA=your-production-client-secret
PHONEPE_MERCHANT_ID_COM_SHAREKARO_KIRANA=your-production-merchant-id
PHONEPE_SALT_KEY_COM_SHAREKARO_KIRANA=your-production-salt-key
PHONEPE_SALT_INDEX_COM_SHAREKARO_KIRANA=1
PHONEPE_CLIENT_VERSION_COM_SHAREKARO_KIRANA=1
PHONEPE_ENV_COM_SHAREKARO_KIRANA=PRODUCTION

# R2 Storage (Cloudflare)
# Enable "Public Development URL" on your bucket in Cloudflare dashboard, then copy the exact URL shown
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=uploads
# Public URL for serving uploaded files (CDN or R2 public domain). Path is appended as /{key}
# NOTE: Use cnd.storyowl.app (not cdn) - cdn.storyowl.app does not resolve
# R2_PUBLIC_DOMAIN=https://cnd.storyowl.app
# R2_PROJECT_FOLDER=sharekaro-andriod

# Analytics - Multi-app configuration
# ======================================
# Each app needs its own credentials following the pattern:
# App ID format: com.example.app -> COM_EXAMPLE_APP (dots to underscores, uppercase)

# com.paymentalert.app
FACEBOOK_PIXEL_ID_COM_PAYMENTALERT_APP=your-pixel-id
FACEBOOK_ACCESS_TOKEN_COM_PAYMENTALERT_APP=your-facebook-access-token
FACEBOOK_APP_ID_COM_PAYMENTALERT_APP=your-facebook-app-id
MIXPANEL_TOKEN_COM_PAYMENTALERT_APP=your-mixpanel-token
FIREBASE_MEASUREMENT_ID_COM_PAYMENTALERT_APP=G-XXXXXXXXXX
FIREBASE_API_SECRET_COM_PAYMENTALERT_APP=your-firebase-api-secret

# com.sharekaro.kirana
FACEBOOK_PIXEL_ID_COM_SHAREKARO_KIRANA=your-pixel-id
FACEBOOK_ACCESS_TOKEN_COM_SHAREKARO_KIRANA=your-facebook-access-token
FACEBOOK_APP_ID_COM_SHAREKARO_KIRANA=your-facebook-app-id
MIXPANEL_TOKEN_COM_SHAREKARO_KIRANA=your-mixpanel-token
FIREBASE_MEASUREMENT_ID_COM_SHAREKARO_KIRANA=G-XXXXXXXXXX
FIREBASE_API_SECRET_COM_SHAREKARO_KIRANA=your-firebase-api-secret

# Firebase Admin SDK
# ==========================================
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
